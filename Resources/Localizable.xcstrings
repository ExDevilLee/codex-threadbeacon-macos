    "Rename 索引不可用，已回退原始标题" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Rename index unavailable; using original titles" } } } },
    "服务异常日志不可用，服务错误状态可能缺失" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Service incident logs unavailable; service error status may be missing" } } } },
