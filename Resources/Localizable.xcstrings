    "双击在 Codex App 中打开" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Double-click to open in Codex App" } } } },
    "无法打开 Codex 任务" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Could Not Open Codex Task" } } } },
    "已归档任务无法在 Codex App 中打开。" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Archived tasks cannot be opened in Codex App." } } } },
    "打开任务失败：尚未获得辅助功能权限。" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Could not open the task: Accessibility permission has not been granted." } } } },
    "打开任务已停止：另一个辅助功能操作正在执行。" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Opening stopped because another Accessibility operation is in progress." } } } },
    "已授权；当前仅用于继续验证，自动发送仍然关闭。" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Authorized for continued validation only; automatic sending remains disabled." } } } },
    "ThreadBeacon 只有在获得此权限后，才可能控制 Codex App 输入框。当前自动发送仍然关闭。" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "ThreadBeacon can control the Codex App input field only after this permission is granted. Automatic sending remains disabled." } } } },
    "验证 Codex 只读访问" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Verify Read-Only Codex Access" } } } },
    "只读验证失败：尚未获得辅助功能权限。" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Read-only verification failed: Accessibility permission has not been granted." } } } },
    "只读验证失败：Codex App 未运行。" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Read-only verification failed: Codex App is not running." } } } },
    "只读验证失败：无法读取 Codex App 的辅助功能结构。" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Read-only verification failed: the Codex App Accessibility structure could not be read." } } } },
    "只读验证通过：%lld 个窗口，%lld 个输入框，访问 %lld 个节点。" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Read-only verification passed: %1$lld window(s), %2$lld text area(s), and %3$lld node(s) visited." } } } },
    "验证当前 Codex 输入框（不发送）" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Verify Current Codex Input (No Send)" } } } },
    "会短暂写入固定提示词，回读后立即清空；已有草稿时拒绝执行。" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Temporarily writes the fixed prompt, reads it back, and clears it immediately. Existing drafts are never overwritten." } } } },
    "输入框验证失败：尚未获得辅助功能权限。" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Input verification failed: Accessibility permission has not been granted." } } } },
    "输入框验证失败：Codex App 未运行。" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Input verification failed: Codex App is not running." } } } },
    "输入框验证失败：找到 %lld 个输入框。" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Input verification failed: found %lld text area(s)." } } } },
    "输入框验证已停止：检测到已有草稿。" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Input verification stopped: an existing draft was detected." } } } },
    "输入框验证失败：当前输入框不可写。" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Input verification failed: the current input field is not writable." } } } },
    "输入框验证失败：无法写入固定提示词。" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Input verification failed: the fixed prompt could not be written." } } } },
    "输入框验证失败：写入后的回读不一致，输入框已清空。" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Input verification failed: the readback did not match; the input field was cleared." } } } },
    "输入框验证失败：无法确认输入框已清空。" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Input verification failed: the input field cleanup could not be confirmed." } } } },
    "输入框验证通过：写入、回读和清空均成功，未发送消息。" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Input verification passed: write, readback, and cleanup succeeded without sending a message." } } } },
    "目标任务 ID" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Target task ID" } } } },
    "切换并验证目标任务（不发送）" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Switch and Verify Target Task (No Send)" } } } },
    "使用任务 ID 打开目标任务，并在 Codex 标题栏核对 rename 名称；当前任务有草稿时会停止。" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Opens the target by task ID and verifies its renamed title in the Codex title bar. Stops if the current task has a draft." } } } },
    "目标任务验证失败：尚未获得辅助功能权限。" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Target task verification failed: Accessibility permission has not been granted." } } } },
    "目标任务验证失败：Codex App 未运行。" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Target task verification failed: Codex App is not running." } } } },
    "目标任务验证已停止：Codex 正在前台，可能存在用户输入。" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Target task verification stopped: Codex is frontmost and the user may be typing." } } } },
    "目标任务验证失败：任务 ID 为空。" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Target task verification failed: the task ID is empty." } } } },
    "目标任务验证失败：无法读取 Codex 任务索引。" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Target task verification failed: the Codex task index could not be read." } } } },
    "目标任务验证失败：未找到该任务的 rename 标题。" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Target task verification failed: no renamed title was found for this task." } } } },
    "目标任务验证已停止：当前 Codex 任务输入框已有草稿。" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Target task verification stopped: the current Codex task has a draft." } } } },
    "目标任务验证已停止：切换前找到 %lld 个输入框。" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Target task verification stopped: found %lld input field(s) before switching." } } } },
    "目标任务验证已停止：无法确认当前 Codex 输入框是否为空。" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Target task verification stopped: the app could not confirm that the current Codex input field is empty." } } } },
    "目标任务验证失败：无法切换 Codex 任务。" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Target task verification failed: the Codex task could not be switched." } } } },
    "目标任务验证失败：标题栏身份匹配数为 %lld。" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Target task verification failed: the title bar identity matched %lld time(s)." } } } },
    "目标任务验证失败：切换后找到 %lld 个输入框。" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Target task verification failed: found %lld input field(s) after switching." } } } },
    "目标任务验证通过：已按 ID 打开并确认 rename 名称，未发送消息。" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Target task verification passed: it was opened by ID and its renamed title was confirmed without sending a message." } } } },
    "发送恢复提示并验证（测试）" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Send Recovery Prompt and Verify (Test)" } } } },
    "确认向目标任务发送恢复提示？" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Send a recovery prompt to the target task?" } } } },
